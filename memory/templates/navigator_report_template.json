{
  "$schema": "navigator_report_schema",
  "description": "Navigator Agent 输出报告模板 - 成功、异常、部分完成三种类型",
  
  "success_report": {
    "status": "completed",
    "exploration_summary": {
      "pages_visited": 0,
      "apis_discovered": 0,
      "forms_found": 0,
      "depth_reached": 0,
      "duration_ms": 0,
      "test_focus_coverage": "",
      "high_risk_apis_found": 0,
      "idor_candidates": 0
    },
    "findings": {
      "pages": [],
      "apis": [],
      "forms": [],
      "pending_urls": []
    },
    "exceptions": [],
    "suggestions": [],
    "requires_user_action": false,
    "user_action_prompt": null
  },
  
  "exception_report": {
    "status": "exception",
    "exploration_summary": {
      "pages_visited": 0,
      "apis_discovered": 0,
      "forms_found": 0,
      "depth_reached": 0,
      "duration_ms": 0
    },
    "findings": {
      "pages": [],
      "apis": [],
      "forms": [],
      "pending_urls": []
    },
    "exceptions": [
      {
        "type": "CAPTCHA_DETECTED",
        "url": "",
        "captcha_type": "image|geetest|recaptcha|h-captcha",
        "description": "",
        "suggestion": "请用户手动完成验证码"
      }
    ],
    "suggestions": [],
    "requires_user_action": true,
    "user_action_prompt": ""
  },
  
  "partial_report": {
    "status": "partial",
    "exploration_summary": {
      "pages_visited": 0,
      "apis_discovered": 0,
      "forms_found": 0,
      "depth_reached": 0,
      "duration_ms": 0,
      "reason": ""
    },
    "findings": {
      "pages": [],
      "apis": [],
      "forms": [],
      "pending_urls": []
    },
    "exceptions": [],
    "suggestions": [],
    "requires_user_action": false
  },
  
  "exception_types": {
    "CAPTCHA_DETECTED": {
      "priority": "critical",
      "requires_user_action": true,
      "handler": "用户手动处理"
    },
    "LOGIN_REQUIRED": {
      "priority": "high",
      "requires_user_action": false,
      "handler": "Coordinator调用Form Agent"
    },
    "SESSION_EXPIRED": {
      "priority": "high",
      "requires_user_action": false,
      "handler": "Coordinator触发重新登录"
    },
    "TOOL_VIOLATION": {
      "priority": "high",
      "requires_user_action": false,
      "handler": "记录违规，Coordinator判断"
    },
    "PAGE_LOAD_FAILED": {
      "priority": "normal",
      "requires_user_action": false,
      "handler": "记录失败URL，继续探索"
    }
  },
  
  "_usage": {
    "load_method": "Read('memory/templates/navigator_report_template.json')",
    "mongodb_write": {
      "pages": "webtest.pages collection",
      "apis": "webtest.apis collection",
      "exceptions": "webtest.events collection"
    }
  }
}