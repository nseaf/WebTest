{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "watcher": {
    "ignore": [
      "**/node_modules/**",
      "**/vendor/**",
      "**/dist/**",
      "**/build/**",
      "**/.git/**",
      "**/.tmp/**",
      "**/result/**"
    ]
  },
  "default_agent": "Coordinator",
  "agent": {
    "Coordinator": {
      "description": "Coordinator: Web渗透测试主控制器，通过@方式调用子Agent，串行执行测试流程。",
      "mode": "primary",
      "temperature": 0.2,
      "prompt": "{file:.opencode/agents/coordinator.md}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "skill": true
      },
      "permission": {
        "task": {
          "navigator": "allow",
          "form": "allow",
          "security": "allow",
          "analyzer": "allow",
          "account_parser": "allow",
          "*": "allow"
        },
        "bash": {
          "*": "ask",
          "browser-use *": "allow",
          "docker *": "allow",
          "curl *": "allow"
        },
        "skill": {
          "*": "allow"
        }
      }
    },
    "navigator": {
      "description": "Navigator Agent: Chrome管理、页面导航、页面分析、API发现、探索进度汇报。合并原Scout功能。",
      "mode": "subagent",
      "temperature": 0.1,
      "prompt": "{file:.opencode/agents/navigator.md}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "skill": true
      },
      "permission": {
        "bash": {
          "*": "ask",
          "browser-use *": "allow"
        },
        "skill": {
          "*": "allow"
        }
      }
    },
    "form": {
      "description": "Form Agent: 表单处理、登录执行、Cookie同步、验证码检测。",
      "mode": "subagent",
      "temperature": 0.1,
      "prompt": "{file:.opencode/agents/form.md}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "skill": true
      },
      "permission": {
        "bash": {
          "*": "ask",
          "browser-use *": "allow"
        },
        "skill": {
          "*": "allow"
        }
      }
    },
    "security": {
      "description": "Security Agent: IDOR测试、注入测试、历史记录分析、BurpBridge集成。",
      "mode": "subagent",
      "temperature": 0.1,
      "prompt": "{file:.opencode/agents/security.md}",
      "tools": {
        "write": true,
        "edit": false,
        "bash": true,
        "skill": true
      },
      "permission": {
        "task": {
          "analyzer": "allow"
        },
        "bash": {
          "*": "ask",
          "docker *": "allow",
          "curl *": "allow"
        },
        "skill": {
          "*": "allow"
        }
      }
    },
    "analyzer": {
      "description": "Analyzer Agent: 重放结果分析、漏洞判定、严重性评级、测试建议生成。",
      "mode": "subagent",
      "temperature": 0.15,
      "prompt": "{file:.opencode/agents/analyzer.md}",
      "tools": {
        "write": true,
        "edit": false,
        "bash": false,
        "skill": true
      },
      "permission": {
        "skill": {
          "*": "allow"
        }
      }
    },
    "account_parser": {
      "description": "Account Parser: 账号文档解析、权限矩阵提取、accounts.json生成。",
      "mode": "subagent",
      "temperature": 0.1,
      "prompt": "{file:.opencode/agents/account_parser.md}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "skill": true
      },
      "permission": {
        "bash": {
          "*": "ask"
        },
        "skill": {
          "*": "allow"
        }
      }
    }
  },
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "skill": {
      "*": "allow"
    }
  }
}