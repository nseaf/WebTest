{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"],
      "env": {
        "HTTP_PROXY": "http://127.0.0.1:8080",
        "HTTPS_PROXY": "http://127.0.0.1:8080"
      }
    },
    "burpbridge": {
      "command": "python",
      "args": ["/Users/fizz/projects/BurpBridge/burp_mcp_server.py"],
      "env": {
        "BURP_BRIDGE_URL": "http://localhost:8090",
        "MONGO_URI": "mongodb://localhost:27017/"
      }
    }
  }
}
